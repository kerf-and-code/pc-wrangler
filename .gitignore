# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# secrets and local credentials (these have leaked before, keep them out)
.Renviron
**/.Renviron
*.b64
gcp-sa-key*.json

# R noise
.Rhistory
.RData
.Rproj.user/
**/.Rhistory
**/.RData

# local spikes and capture debris
dave_spike_spyder.py
beyond20/
captures/

# supabase local state
supabase/.temp/

# --- Six Axes: build artifacts and local scratch ---
filetree.txt
*.lnk
wrangler-disposition/*.exe
wrangler-disposition/disposition_posteriors.csv
six-axes-capture-extension/*.zip
